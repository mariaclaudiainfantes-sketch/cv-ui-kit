## 4. Stories (`ComponentName.stories.tsx`)

### Base Template

```tsx
import { Meta, StoryFn } from '@storybook/react';

import { ComponentName, type ComponentNameProps } from './ComponentName';
import README from './README.md?raw';

export default {
  title: 'Components/ComponentName',
  component: ComponentName,
  parameters: {
    layout: 'centered',
    docs: {
      description: {
        component: README,
      },
    },
  },
  argTypes: {
    variant: {
      control: { type: 'select' },
      options: ['default', 'alternative'],
      description: 'Visual style variant',
      table: {
        type: { summary: '"default" | "alternative"' },
        defaultValue: { summary: '"default"' },
      },
    },
  },
} as Meta<typeof ComponentName>;

const Template: StoryFn<ComponentNameProps> = (args) => <ComponentName {...args} />;

export const Default = Template.bind({});
Default.args = {
  children: 'Content',
};
Default.parameters = {
  docs: {
    description: {
      story: 'Default variant of the component.',
    },
  },
};

export const Alternative = Template.bind({});
Alternative.args = {
  children: 'Alternative content',
  variant: 'alternative',
};
Alternative.parameters = {
  docs: {
    description: {
      story: 'Alternative variant of the component.',
    },
  },
};
```

### Story Conventions

- **Meta title**: `'Components/ComponentName'`
- **Template**: Use `StoryFn<ComponentNameProps>`
- **README.md**: Import as raw string (`import README from './README.md?raw'`) and use as `parameters.docs.description.component` — do not write inline descriptions
- **argTypes**: Define controls with descriptions and default values
- **Stories**: One per important variant/state
- **story.parameters.docs**: Individual description for each story
- **Naming**: PascalCase (`Default`, `Alternative`, `WithIcon`)

---

## 5. Export the Component

After creating the component, add the export in `src/components/index.ts`:

```ts
export { ComponentName } from './ComponentName/ComponentName';
```

If you need to export additional types:

```ts
export { ComponentName, type ComponentNameProps } from './ComponentName/ComponentName';
```

### Export Order

Keep alphabetical order in the `index.ts` file.

---

## Creation Checklist

- [ ] Create folder `src/components/ComponentName/`
- [ ] Create `ComponentName.tsx` with interface and component
- [ ] Create `ComponentName.module.css` with styles
- [ ] Create `ComponentName.test.tsx` with basic tests
- [ ] Create `ComponentName.stories.tsx` with stories
- [ ] Create `README.md` with component documentation
- [ ] Add export in `src/components/index.ts`
- [ ] Run `npm run lint:fix` to format
- [ ] Run `npm run test` to verify tests
- [ ] Run `npm run typecheck` to verify types
- [ ] Check in Storybook (`npm run dev`)

---

## Additional Patterns

### Component with multiple sizes

```tsx
// Props
size?: 'S' | 'M' | 'L';

// Usage with CSS Modules
className={classNames(styles.root, styles[size])}
```

```css
/* CSS */
.S {
  font-size: 14px;
  padding: var(--padding-tb-xs, 4px) var(--padding-rl-m, 16px);
}

.M {
  font-size: 16px;
  padding: var(--padding-tb-s, 8px) var(--padding-rl-m, 16px);
}
```

### Component with controlled/uncontrolled state

```tsx
const [internalValue, setInternalValue] = useState(defaultValue);

const isControlled = value !== undefined;
const currentValue = isControlled ? value : internalValue;

const handleChange = (newValue: Type) => {
  if (!isControlled) setInternalValue(newValue);
  onChange?.(newValue);
};
```

### data-qa with suffixes

```tsx
// For complex components, add descriptive suffixes
data-qa={dataQa ? `${dataQa}-button` : undefined}
data-qa={dataQa ? `${dataQa}-label` : undefined}
data-qa={dataQa ? `${dataQa}-icon` : undefined}
```
