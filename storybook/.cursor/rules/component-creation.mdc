## 3. Tests (`ComponentName.test.tsx`)

### Base Template

```tsx
import { render, screen, fireEvent } from '@testing-library/react';

import { ComponentName } from './ComponentName';

describe('ComponentName Component', () => {
  it('renders children correctly', () => {
    render(<ComponentName>Content</ComponentName>);

    expect(screen.getByText('Content')).toBeInTheDocument();
  });

  it('applies default classes', () => {
    render(<ComponentName>Content</ComponentName>);

    const element = screen.getByText('Content').closest('div');

    expect(element?.className).toMatch(/root/);
    expect(element?.className).toMatch(/default/);
  });

  it('applies variant class correctly', () => {
    render(<ComponentName variant="alternative">Content</ComponentName>);

    const element = screen.getByText('Content').closest('div');

    expect(element?.className).toMatch(/alternative/);
  });

  it('sets data-qa attribute when provided', () => {
    render(<ComponentName data-qa="test-qa">Content</ComponentName>);

    expect(screen.getByText('Content').closest('div')).toHaveAttribute('data-qa', 'test-qa');
  });

  it('does not set data-qa attribute when not provided', () => {
    render(<ComponentName>Content</ComponentName>);

    expect(screen.getByText('Content').closest('div')).not.toHaveAttribute('data-qa');
  });

  it('sets id attribute when provided', () => {
    render(<ComponentName id="test-id">Content</ComponentName>);

    expect(screen.getByText('Content').closest('div')).toHaveAttribute('id', 'test-id');
  });

  it('passes additional props to root element', () => {
    render(<ComponentName aria-label="Test label">Content</ComponentName>);

    expect(screen.getByText('Content').closest('div')).toHaveAttribute('aria-label', 'Test label');
  });
});
```

### Test Conventions

- **Framework**: Vitest + React Testing Library
- **Describe**: Use `describe('ComponentName Component', ...)`
- **Minimum tests**: Rendering, default classes, variants, data-qa, id, additional props
- **Queries**: Prefer `getByRole`, `getByText`, `getByTestId`
- **Class assertions**: Use `element?.className.toMatch(/pattern/)` for CSS Modules
- **Assertions**: Use matchers from `@testing-library/jest-dom`
- **vi.fn()**: For function mocks (NO `jest.fn()`)

