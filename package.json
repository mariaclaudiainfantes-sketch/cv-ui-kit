{
  "author": "Leadtech",
  "description": "CV UI Kit components",
  "version": "15.7.0",
  "files": [
    "dist"
  ],
  "keywords": [
    "components",
    "react",
    "typescript",
    "ui-kit",
    "design-system"
  ],
  "license": "ISC",
  "main": "dist/index.cjs",
  "module": "dist/index.esm.js",
  "name": "@npm_leadtech/cv-ui-kit",
  "source": "src/index.ts",
  "type": "module",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs"
    },
    "./fileUploader": {
      "types": "./dist/fileUploader.d.ts",
      "import": "./dist/fileUploader.esm.js",
      "require": "./dist/fileUploader.cjs"
    },
    "./styles": "./dist/cv-ui-kit.css",
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*"
    }
  },
  "sideEffects": [
    "*.css"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "vite build",
    "build:storybook": "storybook build",
    "chromatic": "chromatic --project-token=$CHROMATIC_PROJECT_TOKEN",
    "clean": "rm -rf dist coverage",
    "dev": "storybook dev -p 6006",
    "dev:watch": "vite build --watch",
    "format": "prettier --write .",
    "lint": "eslint 'src/**/*.{js,jsx,ts,tsx}'",
    "lint:fix": "eslint 'src/**/*.{js,jsx,ts,tsx}' --fix",
    "prepare": "husky || true",
    "test": "vitest run",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest --watch",
    "convert-tokens": "tsx scripts/build-tokens.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "3.2.7",
    "@dnd-kit/core": "6.3.1",
    "@eslint/js": "9.22.0",
    "@storybook/addon-essentials": "8.6.7",
    "@storybook/blocks": "8.6.7",
    "@storybook/experimental-addon-test": "8.6.7",
    "@storybook/react": "8.6.7",
    "@storybook/react-vite": "8.6.7",
    "@storybook/test": "8.6.7",
    "@testing-library/dom": "10.4.0",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.2.0",
    "@testing-library/user-event": "14.5.2",
    "@tokens-studio/sd-transforms": "2.0.3",
    "@types/node": "22.13.10",
    "@types/react": "18.3.0",
    "@types/react-dom": "18.3.0",
    "@vitejs/plugin-react": "4.3.4",
    "@vitest/coverage-v8": "3.0.9",
    "autoprefixer": "10.4.23",
    "chromatic": "13.3.3",
    "eslint": "9.22.0",
    "eslint-config-prettier": "10.1.1",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-prettier": "5.2.3",
    "eslint-plugin-react": "7.37.4",
    "eslint-plugin-storybook": "0.11.6",
    "globals": "16.0.0",
    "husky": "9.1.7",
    "jiti": "2.6.1",
    "jsdom": "26.0.0",
    "lint-staged": "16.2.7",
    "postcss": "8.5.6",
    "postcss-nesting": "13.0.2",
    "prettier": "3.5.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-dropzone": "14.3.8",
    "storybook": "8.6.7",
    "style-dictionary": "5.3.0",
    "tsx": "4.19.2",
    "typescript": "5.8.2",
    "typescript-eslint": "8.26.1",
    "vite": "6.2.2",
    "vite-plugin-dts": "4.5.3",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "3.0.9"
  },
  "dependencies": {
    "classnames": "2.5.1"
  },
  "peerDependencies": {
    "@dnd-kit/core": "^6.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-dropzone": "^14.3.8"
  },
  "peerDependenciesMeta": {
    "@dnd-kit/core": {
      "optional": true
    },
    "react-dropzone": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@bitbucket.org:grupoblidoo/cv-ui-kit.git"
  },
  "bugs": {
    "url": "https://bitbucket.org/grupoblidoo/cv-ui-kit/issues"
  },
  "homepage": "https://bitbucket.org/grupoblidoo/cv-ui-kit#readme"
}
